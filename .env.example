# Copy to .env:  copy .env.example .env

# Ollama (host — Docker reaches via host.docker.internal)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:14b
OLLAMA_PLANNER_MODEL=deepseek-r1:14b

# Runtime backend: false = LangGraph (default, production path)
#                    true  = LoopEngine via runtime adapters (experimental, not production-ready)
USE_LOOP_ENGINE=false

# Agent mode: observe | edit | build | operator
#   observe — read-only tools
#   edit    — workspace writes + safe shell (DEFAULT, safe)
#   build   — + pip/npm/make
#   operator — + docker (requires operator compose overlay)
AGENT_MODE=edit
ENABLE_DOCKER_TOOL=false
SELF_EDIT_MODE=false

# Loop behavior
LOOP_SLEEP_SECONDS=20
HEARTBEAT_SECONDS=60
MAX_ITERATIONS_PER_GOAL=75
MAX_GOAL_ELAPSED_SECONDS=3600
MAX_CONSECUTIVE_FAILURES=5
SEED_DEFAULT_GOAL=false
TOOL_TIMEOUT_SECONDS=180
LOG_LEVEL=INFO

# Dashboard (optional — set a password for defense in depth)
DASHBOARD_PASSWORD=change-me

# SearXNG
SEARXNG_SECRET=change-me-in-env