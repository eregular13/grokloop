# Copy to .env and customize:  copy .env.example .env

# Ollama (host machine — Docker reaches via host.docker.internal)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:14b
# Optional separate model for planning (leave blank to reuse OLLAMA_MODEL)
OLLAMA_PLANNER_MODEL=

# Loop behavior
LOOP_SLEEP_SECONDS=30
HEARTBEAT_SECONDS=60
MAX_ITERATIONS_PER_GOAL=50
SELF_EDIT_MODE=false
TOOL_TIMEOUT_SECONDS=120
LOG_LEVEL=INFO